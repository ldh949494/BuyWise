APP_NAME=BuyWise Backend
APP_ENV=dev
APP_PORT=8000
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=buywise
MYSQL_DATABASE=buywise
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=./vector_store/chroma
CHROMA_PRODUCT_COLLECTION=buywise_products

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
COS_BUCKET=your-cos-bucket
COS_REGION=ap-shanghai

LLM_PROVIDER=mock
VISION_PROVIDER=mock
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
SPEECH_PROVIDER=mock
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_VOICE_FORMAT=

AUTH_API_KEYS=android-dev:dev-token:upload:write,products:write,orders:read,orders:write,feedback:read,feedback:write
ADMIN_JWT_SECRET=dev-admin-jwt-secret
ADMIN_JWT_EXPIRE_MINUTES=480
USER_JWT_SECRET=dev-user-jwt-secret
USER_JWT_EXPIRE_MINUTES=15
USER_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_OTP_MOCK_ENABLED=true
AUTH_OTP_EXPIRE_MINUTES=5
AUTH_OTP_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_PHONE_HOUR_LIMIT=5
AUTH_OTP_PHONE_DAY_LIMIT=20
AUTH_OTP_IP_MINUTE_LIMIT=10
AUTH_OTP_IP_HOUR_LIMIT=100
REQUEST_MAX_BYTES=20971520
UPLOAD_PROVIDER=local
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/wav,audio/mpeg,audio/mp4,audio/ogg
AI_LLM_MAX_CONCURRENCY=5
AI_VISION_MAX_CONCURRENCY=2
AI_SPEECH_MAX_CONCURRENCY=2
AI_PROVIDER_TIMEOUT_SECONDS=30
CAPACITY_RETRY_AFTER_SECONDS=5
CHAT_RATE_LIMIT_PER_MINUTE=60
CHAT_AUTH_RATE_LIMIT_PER_MINUTE=0
CHAT_ANON_RATE_LIMIT_PER_MINUTE=0
CHAT_SESSION_RATE_LIMIT_PER_MINUTE=0
CHAT_SESSION_TOKENS_ENABLED=false
CHAT_ANON_SESSION_TTL_HOURS=24
CHAT_CONTEXT_MAX_MESSAGES=8
CHAT_CONTEXT_MAX_CHARS=6000
AI_CHAT_ACTIONS_REQUIRE_AUTH_IN_PROD=true
AI_CHECKOUT_CONFIRMATION_REQUIRED=true
AI_MEDIA_URL_ALLOWLIST_ENABLED=false
AI_MEDIA_ALLOWED_HOSTS=
VISION_RATE_LIMIT_PER_MINUTE=30
SPEECH_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=20

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://10.0.2.2:8000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
