APP_NAME=BuyWise Backend
APP_ENV=test
APP_PORT=8000
APP_DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=buywise
MYSQL_DATABASE=buywise_test
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=./vector_store/test-chroma
CHROMA_PRODUCT_COLLECTION=buywise_products_test

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=test-placeholder
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=test-placeholder
TENCENT_SECRET_KEY=test-placeholder
COS_BUCKET=test-placeholder
COS_REGION=ap-shanghai

LLM_PROVIDER=mock
VISION_PROVIDER=mock
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
SPEECH_PROVIDER=mock
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_VOICE_FORMAT=

AUTH_API_KEYS=test:test-token:upload:write,products:write,orders:read,orders:write,feedback:read,feedback:write
ADMIN_JWT_SECRET=test-admin-jwt-secret
ADMIN_JWT_EXPIRE_MINUTES=480
REQUEST_MAX_BYTES=20971520
UPLOAD_PROVIDER=local
UPLOAD_DIR=.test_uploads
UPLOAD_PUBLIC_BASE_URL=http://testserver
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/wav,audio/mpeg,audio/mp4,audio/ogg
AI_LLM_MAX_CONCURRENCY=5
AI_VISION_MAX_CONCURRENCY=2
AI_SPEECH_MAX_CONCURRENCY=2
AI_PROVIDER_TIMEOUT_SECONDS=30
CAPACITY_RETRY_AFTER_SECONDS=5
CHAT_RATE_LIMIT_PER_MINUTE=60
VISION_RATE_LIMIT_PER_MINUTE=30
SPEECH_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=20

CORS_ALLOWED_ORIGINS=http://testserver
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
