APP_NAME=BuyWise Backend
APP_ENV=dev
APP_PORT=8000
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=buywise
MYSQL_DATABASE=buywise_dev
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=./vector_store/chroma
CHROMA_PRODUCT_COLLECTION=buywise_products

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-dev-llm-api-key
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=your-dev-tencent-secret-id
TENCENT_SECRET_KEY=your-dev-tencent-secret-key
COS_BUCKET=your-dev-cos-bucket
COS_REGION=ap-shanghai

LLM_PROVIDER=mock

AUTH_API_KEYS=android-dev:dev-token:upload:write,products:write
REQUEST_MAX_BYTES=20971520
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/wav,audio/mpeg,audio/mp4,audio/ogg

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://10.0.2.2:8000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
