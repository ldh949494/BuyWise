APP_NAME=BuyWise Backend
APP_ENV=prod
APP_PORT=8000
APP_DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=your-prod-mysql-host
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=buywise
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=/app/vector_store/chroma
CHROMA_PRODUCT_COLLECTION=buywise_products

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=change-me
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=change-me
TENCENT_SECRET_KEY=change-me
COS_BUCKET=change-me
COS_REGION=ap-shanghai

LLM_PROVIDER=openai
VISION_PROVIDER=llm
SPEECH_PROVIDER=tencent
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh

AUTH_API_KEYS=android-app:change-me-strong-token:upload:write,products:write
REQUEST_MAX_BYTES=20971520
UPLOAD_PROVIDER=cos
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_BASE_URL=https://your-api.example.com
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/wav,audio/mpeg,audio/mp4,audio/ogg

CORS_ALLOWED_ORIGINS=https://your-android-gateway.example.com
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
