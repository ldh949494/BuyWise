APP_NAME=BuyWise Backend
APP_ENV=prod
APP_PORT=8000
APP_DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_DATABASE=buywise
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=/app/vector_store/chroma
CHROMA_PRODUCT_COLLECTION=buywise_products

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=change-me-llm-api-key
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=change-me-tencent-secret-id
TENCENT_SECRET_KEY=change-me-tencent-secret-key
COS_BUCKET=change-me-cos-bucket
COS_REGION=ap-shanghai

LLM_PROVIDER=openai-compatible
VISION_PROVIDER=llm
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
SPEECH_PROVIDER=mock
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_VOICE_FORMAT=

AUTH_API_KEYS=smoke:change-me-smoke-token:orders:read,orders:write,orders:advance,feedback:read,feedback:write;admin:change-me-admin-token:products:write
READINESS_TOKEN=change-me-readiness-token
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
ADMIN_JWT_EXPIRE_MINUTES=480
ALLOW_MOCK_PROVIDERS_IN_PROD=false
EXTERNAL_PURCHASE_FEEDBACK_MODE=immediate
REQUEST_MAX_BYTES=20971520
UPLOAD_PROVIDER=cos
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_BASE_URL=https://api.buywise-beta.example.com
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/wav,audio/mpeg,audio/mp4,audio/ogg
AI_LLM_MAX_CONCURRENCY=5
AI_VISION_MAX_CONCURRENCY=2
AI_SPEECH_MAX_CONCURRENCY=2
AI_PROVIDER_TIMEOUT_SECONDS=30
CAPACITY_RETRY_AFTER_SECONDS=5
CHAT_RATE_LIMIT_PER_MINUTE=60
VISION_RATE_LIMIT_PER_MINUTE=30
SPEECH_RATE_LIMIT_PER_MINUTE=30
UPLOAD_RATE_LIMIT_PER_MINUTE=20

CORS_ALLOWED_ORIGINS=https://admin.buywise-beta.example.com
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
