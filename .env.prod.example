APP_NAME=BuyWise Backend
APP_ENV=prod
APP_PORT=8000
APP_DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MYSQL_HOST=your-prod-mysql-host
MYSQL_PORT=3306
MYSQL_USER=buywise
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=buywise
SQLALCHEMY_ECHO=false

CHROMA_PERSIST_DIR=/app/vector_store/chroma
CHROMA_PRODUCT_COLLECTION=buywise_products

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=change-me
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

TENCENT_SECRET_ID=change-me
TENCENT_SECRET_KEY=change-me
COS_BUCKET=change-me
COS_REGION=ap-shanghai

LLM_PROVIDER=openai
